# Example .env configuration file
# Copy this to .env and fill in your values

# ============================================
# API KEYS (Required)
# ============================================

# HuggingFace Token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Kaggle Credentials (get from https://www.kaggle.com/settings/account)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# SerpAPI Key for web search (get from https://serpapi.com/)
# Free tier: 100 searches/month
SERPAPI_KEY=your_serpapi_key

# Google Gemini API Key (optional, for advanced features)
# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key


# ============================================
# LLM CONFIGURATION (Optional - has defaults)
# ============================================

# Enable/disable local LLM for AI-powered cleaning
USE_LOCAL_LLM=true

# LLM model identifier (must match model loaded in LM Studio)
LLM_MODEL=qwen2.5-7b-instruct

# LM Studio endpoint (default port is 1234)
LLM_ENDPOINT=http://localhost:1234/v1/chat/completions

# LLM generation parameters
LLM_TEMPERATURE=0.2        # Lower = more deterministic (0-1)
LLM_MAX_TOKENS=2000        # Maximum response length
LLM_TIMEOUT=60             # Request timeout in seconds


# ============================================
# PROCESSING LIMITS (Optional - has defaults)
# ============================================

# Maximum file size to download (in MB)
MAX_FILE_SIZE_MB=500

# Maximum rows to process from dataset
MAX_DATASET_ROWS=10000

# Download chunk size (in KB)
CHUNK_SIZE_KB=8


# ============================================
# API SERVER (Optional - has defaults)
# ============================================

# FastAPI server host
API_HOST=0.0.0.0

# FastAPI server port
API_PORT=8000

# Number of Uvicorn workers
API_WORKERS=1


# ============================================
# PATHS (Optional - has defaults)
# ============================================

# Output directory for processed datasets
OUTPUT_DIR=output

# Cache directory for downloads
CACHE_DIR=cache

# Temporary directory for Kaggle downloads
KAGGLE_TEMP_DIR=_kaggle_tmp


# ============================================
# CIRCUIT BREAKER (Optional - has defaults)
# ============================================

# Number of failures before circuit opens
CIRCUIT_BREAKER_THRESHOLD=5

# Time window for failure tracking (seconds)
CIRCUIT_BREAKER_WINDOW_SECONDS=300
